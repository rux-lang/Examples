import Std::Io::Print;

/// Prints FizzBuzz from 1 to n
func FizzBuzz(n: uint) {
    for i in 1..=n {
        if i % 15 == 0 {
            Print("FizzBuzz\n");
        } else if i % 3 == 0 {
            Print("Fizz\n");
        } else if i % 5 == 0 {
            Print("Buzz\n");
        } else {
            Print("{}\n", i);
        }
    }
}

/// Entry point of the program
func Main() -> int {
    FizzBuzz(20);
    return 0;
}
